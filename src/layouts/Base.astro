---
import '../styles/global.css';
import { useTranslations, type Locale } from '../i18n/ui';

interface Props {
  title?: string;
  description?: string;
  /** 頁面專屬結構化資料（schema.org JSON-LD），單一物件或陣列。 */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const locale = (Astro.currentLocale ?? 'zh') as Locale;
const t = useTranslations(locale);

const { title = 'DDD Taiwan', description = t('site.description'), jsonLd } = Astro.props;

const prefix = locale === 'zh' ? '' : `/${locale}`;
const navItems = [
  { href: `${prefix}/`, label: t('nav.home') },
  { href: `${prefix}/events/`, label: t('nav.events') },
  { href: `${prefix}/knowledge/`, label: t('nav.knowledge') },
  { href: `${prefix}/community/`, label: t('nav.community') },
  { href: `${prefix}/governance/`, label: t('nav.governance') },
];

const currentPath = Astro.url.pathname.replace(/\/?$/, '/');

// 語言切換：連到「目前頁面的另一語言版本」。
// 只有這幾頁有雙語版本；其餘（如 /posts/xxx/）退回另一語言的首頁。
const localizedPages = ['/', '/events/', '/knowledge/', '/community/', '/governance/'];
const zhPath = locale === 'zh' ? currentPath : currentPath.replace(/^\/en(\/|$)/, '/');
const isLocalizedPage = localizedPages.includes(zhPath);
let otherLocaleHref: string;
if (locale === 'zh') {
  otherLocaleHref = isLocalizedPage ? `/en${currentPath}` : '/en/';
} else {
  otherLocaleHref = isLocalizedPage ? zhPath : '/';
}

const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const labels =
  locale === 'zh'
    ? { theme: '切換主題', menu: '選單' }
    : { theme: 'Toggle theme', menu: 'Menu' };

const siteUrl = Astro.site?.toString() ?? 'https://ddd-tw.com/';
const ogLocale = locale === 'zh' ? 'zh_TW' : 'en_US';
const ogLocaleAlt = locale === 'zh' ? 'en_US' : 'zh_TW';

// 全站實體：讓搜尋引擎與 AI 把「DDD Taiwan」認成一個明確的組織實體。
const organization = {
  '@type': ['Organization', 'NGO'],
  '@id': `${siteUrl}#organization`,
  name: 'DDD Taiwan',
  alternateName: 'Domain-Driven Design Taiwan',
  url: siteUrl,
  logo: new URL('/og-image.png', Astro.site).toString(),
  description: t('site.description'),
  foundingDate: '2018',
  email: 'dddtw2018@gmail.com',
  areaServed: 'Taiwan',
  knowsLanguage: ['zh-Hant', 'en'],
  knowsAbout: [
    'Domain-Driven Design',
    'Software Architecture',
    'Event Storming',
    'Domain Storytelling',
    'Microservices',
    'Systems Design',
    'Socio-technical Systems',
  ],
  sameAs: [
    'https://github.com/ddd-tw',
    'https://www.youtube.com/channel/UCydw7dbEksG3axEMjHy4BxQ',
    'https://www.facebook.com/DDDCommunity.tw/',
    'https://www.facebook.com/groups/dddesigntw',
    'https://www.instagram.com/ddd_twig/',
    'https://www.meetup.com/domain-driven-design-taiwan-meetup-group/',
    'https://x.com/DddTaiwan',
    'https://www.accupass.com/organizer/detail/2204070436062239115110',
  ],
};
const website = {
  '@type': 'WebSite',
  '@id': `${siteUrl}#website`,
  url: siteUrl,
  name: 'DDD Taiwan',
  description: t('site.description'),
  inLanguage: ['zh-TW', 'en'],
  publisher: { '@id': `${siteUrl}#organization` },
};
const baseGraph = { '@context': 'https://schema.org', '@graph': [organization, website] };

// 避免 JSON-LD 內容中的 "<" 破壞 </script>。
const ld = (obj: unknown) => JSON.stringify(obj).replace(/</g, '\\u003c');
const pageJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---

<!doctype html>
<html lang={locale === 'zh' ? 'zh-TW' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="DDD Taiwan" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site)} />
    <meta property="og:image:alt" content="DDD Taiwan" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@DddTaiwan" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="DDD Taiwan"
      href={new URL('/rss.xml', Astro.site)}
    />
    {
      isLocalizedPage && (
        <>
          <link rel="alternate" hreflang="zh-TW" href={new URL(zhPath, Astro.site)} />
          <link rel="alternate" hreflang="en" href={new URL(`/en${zhPath}`, Astro.site)} />
          <link rel="alternate" hreflang="x-default" href={new URL(zhPath, Astro.site)} />
        </>
      )
    }
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400..700&family=Noto+Sans+TC:wght@300..700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      // 主題三態 auto/dark/light：auto = 當地時間 18:00–06:00 深色。
      // 需在 first paint 前執行以避免閃爍，故 inline 於 head。
      (() => {
        const apply = () => {
          const mode = localStorage.getItem('theme-mode') || 'auto';
          const h = new Date().getHours();
          const dark = mode === 'dark' || (mode === 'auto' && (h >= 18 || h < 6));
          const root = document.documentElement;
          root.classList.remove('theme-dark', 'theme-light');
          root.classList.add(dark ? 'theme-dark' : 'theme-light');
        };
        apply();
        window.__applyTheme = apply;
        setInterval(apply, 5 * 60 * 1000);
      })();
    </script>
    <script type="application/ld+json" set:html={ld(baseGraph)} />
    {pageJsonLd.map((obj) => <script type="application/ld+json" set:html={ld(obj)} />)}
  </head>
  <body>
    <nav class="nav" id="site-nav">
      <div class="container nav__inner">
        <a class="nav__brand" href={`${prefix}/`}>
          <img src="/logo.svg" alt="" width="34" height="34" />
          <span>DDD TAIWAN</span>
        </a>
        <div class="nav__right">
          <div class="nav__links">
            {
              navItems.map((item) => (
                <a
                  class="nav__link"
                  href={item.href}
                  aria-current={currentPath === item.href ? 'page' : undefined}
                >
                  {item.label}
                </a>
              ))
            }
          </div>
          <div class="nav__actions">
            <a class="nav__btn" href={otherLocaleHref} aria-label={locale === 'zh' ? '切換到英文' : 'Switch to Chinese'}>
              {locale === 'zh' ? 'EN' : '中'}
            </a>
            <button class="nav__btn" data-theme-toggle aria-label={labels.theme}>◐</button>
            <button class="nav__hamburger" data-menu-toggle aria-label={labels.menu} aria-expanded="false">
              ☰
            </button>
          </div>
        </div>
      </div>
      <div class="nav__mobile">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="container footer__inner">
        <a class="nav__brand" href={`${prefix}/`} style="font-size: 13px;">
          <img src="/logo.svg" alt="" width="24" height="24" />
          <span>DDD TAIWAN</span>
        </a>
        <div class="footer__links">
          <a href={`${prefix}/governance/#privacy`}>{t('footer.privacy')}</a>
          <a href={`${prefix}/governance/#coc`}>{t('footer.coc')}</a>
          <a href="https://github.com/ddd-tw">GitHub</a>
          <a href="https://www.youtube.com/channel/UCydw7dbEksG3axEMjHy4BxQ">YouTube</a>
          <span>© 2026 DDD Taiwan</span>
        </div>
      </div>
    </footer>

    <script>
      const ICONS: Record<string, string> = { auto: '◐', dark: '☾', light: '☀' };
      const NEXT: Record<string, string> = { auto: 'dark', dark: 'light', light: 'auto' };

      const syncIcons = () => {
        const mode = localStorage.getItem('theme-mode') || 'auto';
        document
          .querySelectorAll('[data-theme-toggle]')
          .forEach((btn) => (btn.textContent = ICONS[mode] ?? '◐'));
      };
      syncIcons();

      document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const mode = localStorage.getItem('theme-mode') || 'auto';
          localStorage.setItem('theme-mode', NEXT[mode] ?? 'auto');
          (window as any).__applyTheme?.();
          syncIcons();
        });
      });

      const nav = document.getElementById('site-nav');
      const menuBtn = document.querySelector('[data-menu-toggle]');
      menuBtn?.addEventListener('click', () => {
        const open = nav?.classList.toggle('nav--open') ?? false;
        menuBtn.setAttribute('aria-expanded', String(open));
        menuBtn.textContent = open ? '✕' : '☰';
      });
    </script>
  </body>
</html>
