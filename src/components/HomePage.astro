---
import Base from '../layouts/Base.astro';
import type { Locale } from '../i18n/ui';

const locale = (Astro.currentLocale ?? 'zh') as Locale;
const isEn = locale === 'en';
const prefix = isEn ? '/en' : '';

const entries = isEn
  ? [
      {
        href: `${prefix}/events/`,
        eyebrow: 'Events',
        title: 'Join an Event',
        desc: 'Meetups, the annual conference, and book clubs — model real problems hands-on, alongside fellow practitioners.',
        cta: 'View events →',
      },
      {
        href: `${prefix}/knowledge/`,
        eyebrow: 'Knowledge',
        title: 'Knowledge Base',
        desc: 'Books, articles, videos, and open-source projects — self-guided learning from first steps to deep water.',
        cta: 'Start exploring →',
      },
      {
        href: `${prefix}/community/`,
        eyebrow: 'Community',
        title: 'Join the Community',
        desc: 'Facebook, Line, YouTube — ask, share, contribute, and keep the knowledge flowing.',
        cta: 'Join us →',
      },
    ]
  : [
      {
        href: `${prefix}/events/`,
        eyebrow: 'Events',
        title: '參與活動',
        desc: 'Meetup、年會與讀書會 — 在真實案例與工作坊中，和同路人一起動手建模。',
        cta: '查看活動 →',
      },
      {
        href: `${prefix}/knowledge/`,
        eyebrow: 'Knowledge',
        title: '知識庫',
        desc: '書單、文章、影片與開源專案 — 從入門到深水區，自主學習的資源集散地。',
        cta: '開始探索 →',
      },
      {
        href: `${prefix}/community/`,
        eyebrow: 'Community',
        title: '加入社群',
        desc: 'Facebook、Line、YouTube — 提問、分享、貢獻，成為讓知識流動的一份子。',
        cta: '加入我們 →',
      },
    ];
---

<Base title="DDD Taiwan — Domain-Driven Design Taiwan">
  <section class="container" style="text-align: center; padding-top: 92px; padding-bottom: 72px;">
    <img src="/logo.svg" alt="DDD Taiwan logo" width="104" height="104" />
    <p class="eyebrow" style="margin-top: 28px;">DOMAIN-DRIVEN DESIGN · TAIWAN</p>
    <h1 style="font-size: 48px; line-height: 1.28; font-weight: 700; margin: 16px 0;">
      {
        isEn ? (
          <>
            Start from the <span class="hl">problem domain</span>,<br />
            deliver solutions that truly matter.
          </>
        ) : (
          <>
            從<span class="hl">問題領域</span>出發，<br />催生真正有價值的解決方案。
          </>
        )
      }
    </h1>
    <p style="max-width: 620px; margin: 0 auto; font-size: 17px; color: var(--ink-mid);">
      {
        isEn
          ? 'DDD Taiwan is a community-driven home for people who want to go deeper into systems and software design — and use that depth to solve complex business problems. We started with Domain-Driven Design and keep widening the lens: working from the business perspective, uncovering the problems truly worth solving, and modelling resilient systems that can evolve for the long run. Knowledge here is shared in a decentralised way — every member can contribute, and everyone learns from one another.'
          : 'DDD Taiwan 是社群驅動的學習平台，聚集想深入理解系統與軟體設計、進而解決複雜商業問題的人。我們從領域驅動設計出發，持續拓展視野 — 從業務視角探索真正值得解決的問題，透過建模與跨角色協作，打造能長期演進的韌性系統。這裡的知識以去中心化的方式分享：每個成員都能貢獻，也都能從彼此身上學習。'
      }
    </p>
    <div style="display: flex; gap: 14px; justify-content: center; margin-top: 32px; flex-wrap: wrap;">
      <a class="btn btn--solid" href={`${prefix}/events/`}>{isEn ? 'Join an event' : '參與下一場活動'}</a>
      <a class="btn btn--ghost" href={`${prefix}/knowledge/`}>{isEn ? 'Browse the knowledge base' : '瀏覽知識庫'}</a>
    </div>
  </section>

  <section class="container">
    <div class="grid-3">
      {
        entries.map((e) => (
          <a class="card" href={e.href}>
            <p class="eyebrow eyebrow--accent" style="margin: 0;">
              {e.eyebrow}
            </p>
            <h2 style="font-size: 23px; margin: 10px 0 8px;">{e.title}</h2>
            <p style="font-size: 14.5px; color: var(--ink-mid); margin: 0 0 14px;">{e.desc}</p>
            <span style="font-size: 13px; color: var(--brand-strong);">{e.cta}</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="container section">
    <div
      class="card"
      style="background: var(--banner-bg); border: none; display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap;"
    >
      <div>
        <p class="eyebrow eyebrow--accent" style="color: #e06a4f; margin: 0;">Annual Conference</p>
        <h2 style="font-size: 24px; color: #fbf8f1; margin: 8px 0;">
          {isEn ? 'DDD Taiwan Annual Conference' : 'DDD Taiwan 年度大會'}
        </h2>
        <p style="color: #b9c2d4; font-size: 14.5px; margin: 0;">
          {
            isEn
              ? 'Our flagship community gathering — talks, workshops, and speakers from home and abroad.'
              : '一年一度的社群盛會 — 議程、工作坊與海內外講者。'
          }
        </p>
      </div>
      <a
        class="btn btn--ghost"
        style="border-color: rgba(251,248,241,0.45); color: #fbf8f1;"
        href="https://conference.ddd-tw.com/"
      >
        {isEn ? 'Conference site →' : '前往年會官網 →'}
      </a>
    </div>
  </section>
</Base>
