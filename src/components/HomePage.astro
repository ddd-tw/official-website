---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import type { Locale } from '../i18n/ui';

const locale = (Astro.currentLocale ?? 'zh') as Locale;
const isEn = locale === 'en';
const prefix = isEn ? '/en' : '';

const organizers = await getCollection('contributors');
// 無大頭照者以姓名縮寫的圓形頭像呈現；顏色依序取自品牌色盤。
const AVATAR_COLORS = ['#24417E', '#2B52A0', '#c34a33', '#3e6ac0'];
const initials = (n: string) =>
  n
    .split(/\s+/)
    .slice(0, 2)
    .map((w) => w[0])
    .join('')
    .toUpperCase();

// social link 顯示標籤（website 改顯示網域）
const linkLabels: [string, string][] = [
  ['github', 'GitHub'],
  ['linkedin', 'LinkedIn'],
  ['x', 'X'],
  ['website', 'Website'],
];

// 社群圖示（24x24 inline SVG，用 currentColor 上色）
const socialIcons: Record<string, string> = {
  website:
    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3c2.5 2.5 3.8 5.7 3.8 9s-1.3 6.5-3.8 9c-2.5-2.5-3.8-5.7-3.8-9S9.5 5.5 12 3z"/></svg>',
  linkedin:
    '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4.98 3.5A2.5 2.5 0 1 1 0 3.5a2.5 2.5 0 0 1 4.98 0zM.5 8h4V24h-4V8zM8 8h3.8v2.2h.05c.53-1 1.83-2.2 3.77-2.2 4.03 0 4.78 2.65 4.78 6.1V24h-4v-6.9c0-1.65-.03-3.77-2.3-3.77-2.3 0-2.65 1.8-2.65 3.65V24H8V8z"/></svg>',
  x:
    '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.24 2H21.5l-7.5 8.57L23 22h-7l-5.2-6.8L4.8 22H1.5l8.02-9.17L1 2h7.2l4.7 6.2L18.24 2zm-1.15 18h1.8L7.02 3.9H5.1L17.09 20z"/></svg>',
  github:
    '<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.73.5.5 5.73.5 12a11.5 11.5 0 0 0 7.86 10.93c.58.1.79-.25.79-.56v-2c-3.2.7-3.87-1.54-3.87-1.54-.53-1.34-1.3-1.7-1.3-1.7-1.06-.72.08-.71.08-.71 1.17.08 1.79 1.2 1.79 1.2 1.04 1.78 2.73 1.27 3.4.97.1-.75.4-1.27.73-1.56-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.24 2.76.12 3.05.74.81 1.18 1.84 1.18 3.1 0 4.43-2.69 5.4-5.25 5.69.41.35.78 1.05.78 2.12v3.14c0 .31.2.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5z"/></svg>',
};

const entries = isEn
  ? [
      {
        href: `${prefix}/events/`,
        eyebrow: 'Events',
        title: 'Join an Event',
        desc: 'Meetups, the annual conference, and book clubs — model real problems hands-on, alongside fellow practitioners.',
        cta: 'View events →',
      },
      {
        href: `${prefix}/knowledge/`,
        eyebrow: 'Knowledge',
        title: 'Knowledge Base',
        desc: 'Books, articles, videos, and open-source projects — self-guided learning from first steps to deep water.',
        cta: 'Start exploring →',
      },
      {
        href: `${prefix}/community/`,
        eyebrow: 'Community',
        title: 'Join the Community',
        desc: 'Facebook, Line, YouTube — ask, share, contribute, and keep the knowledge flowing.',
        cta: 'Join us →',
      },
    ]
  : [
      {
        href: `${prefix}/events/`,
        eyebrow: 'Events',
        title: '參與活動',
        desc: 'Meetup、年會與讀書會 — 在真實案例與工作坊中，和同路人一起動手建模。',
        cta: '查看活動 →',
      },
      {
        href: `${prefix}/knowledge/`,
        eyebrow: 'Knowledge',
        title: '知識庫',
        desc: '書單、文章、影片與開源專案 — 從入門到深水區，自主學習的資源集散地。',
        cta: '開始探索 →',
      },
      {
        href: `${prefix}/community/`,
        eyebrow: 'Community',
        title: '加入社群',
        desc: 'Facebook、Line、YouTube — 提問、分享、貢獻，成為讓知識流動的一份子。',
        cta: '加入我們 →',
      },
    ];

const site = Astro.site?.toString() ?? 'https://ddd-tw.com/';
const homeUrl = new URL(`${prefix}/`, site).toString();
const nav = [
  { name: isEn ? 'Events' : '參與活動', path: '/events/' },
  { name: isEn ? 'Knowledge' : '知識庫', path: '/knowledge/' },
  { name: isEn ? 'Community' : '社群', path: '/community/' },
  { name: isEn ? 'Governance' : '治理', path: '/governance/' },
];
// 首頁 = 網站入口與主要區塊的集合頁；SiteNavigationElement 讓引擎/agent 一眼看懂站點結構。
const homeLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': homeUrl,
  url: homeUrl,
  name: 'DDD Taiwan — Domain-Driven Design Taiwan',
  inLanguage: isEn ? 'en' : 'zh-TW',
  isPartOf: { '@id': `${site}#website` },
  about: { '@id': `${site}#organization` },
  primaryImageOfPage: new URL('/og-image.png', site).toString(),
  hasPart: nav.map((n) => ({
    '@type': 'SiteNavigationElement',
    name: n.name,
    url: new URL(`${prefix}${n.path}`, site).toString(),
  })),
};
---

<Base title="DDD Taiwan — Domain-Driven Design Taiwan" jsonLd={homeLd}>
  <section class="container" style="text-align: center; padding-top: 92px; padding-bottom: 72px;">
    <img src="/logo.svg" alt="DDD Taiwan logo" width="104" height="104" />
    <p class="eyebrow" style="margin-top: 28px;">DOMAIN-DRIVEN DESIGN · TAIWAN</p>
    <h1 style="font-size: 48px; line-height: 1.28; font-weight: 700; margin: 16px 0;">
      {
        isEn ? (
          <>
            Start from the <span class="hl">problem domain</span>,<br />
            deliver solutions that truly matter.
          </>
        ) : (
          <>
            從<span class="hl">問題領域</span>出發，<br />催生真正有價值的解決方案。
          </>
        )
      }
    </h1>
    <p style="max-width: 620px; margin: 0 auto; font-size: 17px; color: var(--ink-mid);">
      {
        isEn
          ? 'DDD Taiwan is a community-driven home for people who want to go deeper into systems and software design — and use that depth to solve complex business problems. We started with Domain-Driven Design and keep widening the lens: working from the business perspective, uncovering the problems truly worth solving, and modelling resilient systems that can evolve for the long run. Knowledge here is shared in a decentralised way — every member can contribute, and everyone learns from one another.'
          : 'DDD Taiwan 是社群驅動的學習平台，聚集想深入理解系統與軟體設計、進而解決複雜商業問題的人。我們從領域驅動設計出發，持續拓展視野 — 從業務視角探索真正值得解決的問題，透過建模與跨角色協作，打造能長期演進的韌性系統。這裡的知識以去中心化的方式分享：每個成員都能貢獻，也都能從彼此身上學習。'
      }
    </p>
    <div style="display: flex; gap: 14px; justify-content: center; margin-top: 32px; flex-wrap: wrap;">
      <a class="btn btn--solid" href={`${prefix}/events/`}>{isEn ? 'Join an event' : '參與下一場活動'}</a>
      <a class="btn btn--ghost" href={`${prefix}/knowledge/`}>{isEn ? 'Browse the knowledge base' : '瀏覽知識庫'}</a>
    </div>
  </section>

  <section class="container">
    <div class="grid-3">
      {
        entries.map((e) => (
          <a class="card" href={e.href}>
            <p class="eyebrow eyebrow--accent" style="margin: 0;">
              {e.eyebrow}
            </p>
            <h2 style="font-size: 23px; margin: 10px 0 8px;">{e.title}</h2>
            <p style="font-size: 14.5px; color: var(--ink-mid); margin: 0 0 14px;">{e.desc}</p>
            <span style="font-size: 13px; color: var(--brand-strong);">{e.cta}</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="container section">
    <div
      class="card"
      style="background: var(--banner-bg); border: none; display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap;"
    >
      <div>
        <p class="eyebrow eyebrow--accent" style="color: #e06a4f; margin: 0;">Annual Conference</p>
        <h2 style="font-size: 24px; color: #fbf8f1; margin: 8px 0;">
          {isEn ? 'DDD Taiwan Annual Conference' : 'DDD Taiwan 年度大會'}
        </h2>
        <p style="color: #b9c2d4; font-size: 14.5px; margin: 0;">
          {
            isEn
              ? 'Our flagship community gathering — talks, workshops, and speakers from home and abroad.'
              : '一年一度的社群盛會 — 議程、工作坊與海內外講者。'
          }
        </p>
      </div>
      <a
        class="btn btn--ghost"
        style="border-color: rgba(251,248,241,0.45); color: #fbf8f1;"
        href="https://conference.ddd-tw.com/"
      >
        {isEn ? 'Conference site →' : '前往年會官網 →'}
      </a>
    </div>
  </section>

  <section class="container section">
    <p class="eyebrow eyebrow--accent" style="margin: 0 0 6px;">Organizers</p>
    <h2 style="font-size: 26px; margin: 0 0 8px;">{isEn ? 'Our organizers' : '社群籌辦團隊'}</h2>
    <p style="color: var(--ink-mid); font-size: 14.5px; max-width: 620px; margin: 0 0 8px;">
      {
        isEn
          ? 'DDD Taiwan is organized by a group of volunteers — more have joined to help run it with every passing year.'
          : 'DDD Taiwan 由一群志工共同籌辦 — 從第一場聚會到現在，愈來愈多人一起投入幫忙。'
      }
    </p>
    <div class="orgx">
      <button class="orgx__arrow orgx__arrow--prev" type="button" data-dir="-1" aria-label={isEn ? 'Previous' : '上一組'}>‹</button>
      <div class="orgx__viewport">
        <div class="orgx__track">
          {
            organizers.map((c, i) => {
              const name = isEn ? (c.data.nameEn ?? c.data.name) : c.data.name;
              const role = isEn ? c.data.roleEn : c.data.role;
              const tagline = isEn ? c.data.taglineEn : c.data.tagline;
              const links = c.data.links ?? {};
              const hasLinks = linkLabels.some(([key]) => links[key]);
              return (
                <article class="orgx__card">
                  <div class="orgx__photo">
                    {c.data.photo ? (
                      <img src={c.data.photo} alt={name} loading="lazy" />
                    ) : (
                      <span class="orgx__mono" style={`background: ${AVATAR_COLORS[i % AVATAR_COLORS.length]};`}>
                        {initials(c.data.nameEn ?? c.data.name)}
                      </span>
                    )}
                  </div>
                  <div class="orgx__info">
                    <h3 class="orgx__name">{name}</h3>
                    <p class="orgx__role">{tagline || role}</p>
                    {hasLinks && (
                      <>
                        <span class="orgx__rule" />
                        <div class="orgx__social">
                          {linkLabels.map(([key, label]) =>
                            links[key] ? (
                              <a
                                class="orgx__icon"
                                href={links[key]}
                                target="_blank"
                                rel="noopener"
                                aria-label={label}
                                title={label}
                                set:html={socialIcons[key]}
                              />
                            ) : null
                          )}
                        </div>
                      </>
                    )}
                  </div>
                </article>
              );
            })
          }
        </div>
      </div>
      <button class="orgx__arrow orgx__arrow--next" type="button" data-dir="1" aria-label={isEn ? 'Next' : '下一組'}>›</button>
      <div class="orgx__dots" aria-label={isEn ? 'Carousel pages' : '輪播頁'} />
    </div>
    <script>
      {
        const INTERVAL = 3800; // 自動輪播間隔（毫秒），一次一位
        const CLONES = 4; // 兩端各複製幾張以達成無縫循環（≥ 最大同時可見數）
        const root = document.querySelector('.orgx');
        const track = root && root.querySelector('.orgx__track');
        const dotsWrap = root && root.querySelector('.orgx__dots');
        if (track && track.children.length > 1) {
          const reals = Array.from(track.children);
          const N = reals.length;
          const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

          // 兩端各補 CLONES 張複製卡，讓前後都能無縫繞回
          const headClones = reals.slice(0, CLONES).map((el) => el.cloneNode(true));
          const tailClones = reals.slice(-CLONES).map((el) => el.cloneNode(true));
          [...headClones, ...tailClones].forEach((el) => {
            el.setAttribute('aria-hidden', 'true');
            el.querySelectorAll('a').forEach((a) => (a.tabIndex = -1));
          });
          tailClones.forEach((el) => track.insertBefore(el, track.firstChild));
          headClones.forEach((el) => track.appendChild(el));

          let pos = CLONES; // 第一張真實卡的位置
          const step = () => {
            const first = track.children[0];
            const gap = parseFloat(getComputedStyle(track).gap) || 0;
            return first.getBoundingClientRect().width + gap;
          };
          const place = (animate) => {
            track.style.transition = animate ? '' : 'none';
            track.style.transform = `translateX(${-pos * step()}px)`;
            if (!animate) { void track.offsetWidth; track.style.transition = ''; }
          };
          const logical = () => (((pos - CLONES) % N) + N) % N;
          const paintDots = () => {
            if (!dotsWrap) return;
            Array.from(dotsWrap.children).forEach((d, i) => d.classList.toggle('is-active', i === logical()));
          };

          // 圓點：一位一個
          if (dotsWrap) {
            for (let i = 0; i < N; i++) {
              const b = document.createElement('button');
              b.type = 'button';
              b.className = 'orgx__dot';
              b.setAttribute('aria-label', `${i + 1}`);
              b.addEventListener('click', () => { pos = CLONES + i; place(true); paintDots(); restart(); });
              dotsWrap.appendChild(b);
            }
          }

          const go = (d) => { pos += d; place(true); paintDots(); };
          track.addEventListener('transitionend', () => {
            if (pos >= CLONES + N) { pos -= N; place(false); }
            else if (pos < CLONES) { pos += N; place(false); }
          });

          let timer = null;
          const stop = () => { if (timer) { clearInterval(timer); timer = null; } };
          const start = () => { stop(); if (!reduce) timer = setInterval(() => go(1), INTERVAL); };
          const restart = () => start();

          root.querySelectorAll('[data-dir]').forEach((b) =>
            b.addEventListener('click', () => { go(Number(b.dataset.dir)); restart(); })
          );
          root.addEventListener('mouseenter', stop);
          root.addEventListener('mouseleave', start);
          root.addEventListener('focusin', stop);
          root.addEventListener('focusout', start);
          let t;
          window.addEventListener('resize', () => { clearTimeout(t); t = setTimeout(() => place(false), 150); });

          place(false);
          paintDots();
          start();
        }
      }
    </script>
  </section>
</Base>
