---
import Base from '../layouts/Base.astro';
import type { Locale } from '../i18n/ui';

const locale = (Astro.currentLocale ?? 'zh') as Locale;
const isEn = locale === 'en';
const prefix = isEn ? '/en' : '';

const toc = isEn
  ? [
      { id: 'how-we-run', label: 'How we operate' },
      { id: 'privacy', label: 'Privacy' },
      { id: 'coc', label: 'Code of Conduct' },
    ]
  : [
      { id: 'how-we-run', label: '運作方式' },
      { id: 'privacy', label: '隱私權政策' },
      { id: 'coc', label: '行為準則' },
    ];
---

<Base title={isEn ? 'Governance — DDD Taiwan' : '治理 — DDD Taiwan'}>
  <div class="container container--narrow page-head">
    <p class="eyebrow">Governance</p>
    <h1>
      {
        isEn ? (
          <>
            Governance & <span class="hl">policy</span>
          </>
        ) : (
          <>
            治理與<span class="hl">政策</span>
          </>
        )
      }
    </h1>
    <p style="max-width: 620px; color: var(--ink-mid);">
      {
        isEn
          ? 'How DDD Taiwan is run, and our policies on privacy and community conduct.'
          : 'DDD Taiwan 如何運作，以及我們對隱私與社群互動的準則。'
      }
    </p>
    <p class="gov-toc">
      {
        toc.map((t, i) => (
          <>
            {i > 0 && <span class="gov-toc__sep">·</span>}
            <a href={`#${t.id}`}>{t.label}</a>
          </>
        ))
      }
    </p>
    <p class="gov-updated">{isEn ? 'Last updated: July 2026' : '最後更新：2026 年 7 月'}</p>
  </div>

  <!-- 運作方式 -->
  <section class="container container--narrow section">
    <h2 class="kb-label kb-label--rule gov-h" id="how-we-run">{isEn ? 'How we operate' : '運作方式'}</h2>

    <h3>{isEn ? 'Volunteer-run & non-profit' : '非營利、志工經營'}</h3>
    <p class="gov-p">
      {
        isEn
          ? 'Founded in 2018, DDD Taiwan is a non-profit, volunteer-run technical community. We operate and share knowledge in a decentralised way, not for profit.'
          : 'DDD Taiwan 自 2018 年成立，是非營利、由志工經營的技術社群。我們以去中心化的方式運作、分享知識，不以營利為目的。'
      }
    </p>

    <h3>{isEn ? 'Organizing & decisions' : '籌辦與決策'}</h3>
    <p class="gov-p">
      {
        isEn ? (
          <>
            The community is run by a team of volunteer <a href={`${prefix}/`}>organizers</a>;
            direction and key decisions are made together by the team, not by any single person.
          </>
        ) : (
          <>
            社群由一群<a href={`${prefix}/`}>籌辦志工</a
            >共同經營；活動方向與重要決策由團隊一起討論決定，而非集中於單一個人。
          </>
        )
      }
    </p>

    <h3>{isEn ? 'Funding & sponsorship' : '經費與贊助'}</h3>
    <p class="gov-p">
      {
        isEn ? (
          <>
            Meetups and the annual conference are supported by ticket revenue and corporate
            sponsorship. For sponsorship, email{' '}
            <a href="mailto:conference@ddd-tw.com" class="mono">conference@ddd-tw.com</a>.
          </>
        ) : (
          <>
            聚會與年度大會的營運，由活動售票收入與企業贊助支持。贊助洽詢請來信{' '}
            <a href="mailto:conference@ddd-tw.com" class="mono">conference@ddd-tw.com</a>。
          </>
        )
      }
    </p>

    <h3>{isEn ? 'Openness & open source' : '開放與開源'}</h3>
    <p class="gov-p">
      {
        isEn ? (
          <>
            We believe knowledge should flow openly. This website and several community projects are
            open-source on <a href="https://github.com/ddd-tw">GitHub</a>; articles republished in
            the Knowledge base carry the original authors' permission.
          </>
        ) : (
          <>
            我們相信知識應該開放流動。官網與多個社群專案皆在{' '}
            <a href="https://github.com/ddd-tw">GitHub</a>{' '}
            開源；知識庫中轉載的文章，均取得原作者授權。
          </>
        )
      }
    </p>
  </section>

  <!-- 隱私權政策 -->
  <section class="container container--narrow section">
    <h2 class="kb-label kb-label--rule gov-h" id="privacy">{isEn ? 'Privacy Policy' : '隱私權政策'}</h2>

    <h3>{isEn ? 'Collection & Use' : '蒐集與使用'}</h3>
    <p class="gov-p">
      {
        isEn
          ? 'We collect only the personal data needed for event registration and contact (such as name and email address), and use it solely for event notifications and community operations.'
          : '我們僅在活動報名與聯繫時蒐集必要的個人資料（如姓名、Email），用於活動通知與社群營運。'
      }
    </p>

    <h3>{isEn ? 'Protection & Compliance' : '保護與法遵'}</h3>
    <p class="gov-p">
      {
        isEn
          ? "Personal data is handled in accordance with Taiwan's Personal Data Protection Act and in the spirit of the GDPR; event registration data is processed on our behalf by the ticketing platform."
          : '遵循個人資料保護法並參考 GDPR 精神處理個資；活動報名資料由售票平台代為處理。'
      }
    </p>

    <h3>{isEn ? 'Third-Party Services' : '第三方服務'}</h3>
    <p class="gov-p">
      {
        isEn
          ? 'This is a static website hosted on GitHub Pages, with fonts served by Google Fonts — both process your IP address when you visit. The site itself sets no tracking cookies. Links to external platforms (Facebook, Line, YouTube, Accupass, etc.) are governed by those platforms’ own privacy policies.'
          : '本網站為靜態網站，由 GitHub Pages 代管、字體由 Google Fonts 提供，瀏覽時你的 IP 位址會經由這些服務處理；本站本身不設任何追蹤 cookie。連往外部平台（Facebook、Line、YouTube、Accupass 等）後，適用各該平台自己的隱私權政策。'
      }
    </p>

    <h3>{isEn ? 'Your Rights' : '你的權利'}</h3>
    <p class="gov-p">
      {
        isEn ? (
          <>
            You may email <a href="mailto:dddtw2018@gmail.com" class="mono">dddtw2018@gmail.com</a>{' '}
            at any time to access, correct, or request deletion of your personal data.
          </>
        ) : (
          <>
            你可隨時來信 <a href="mailto:dddtw2018@gmail.com" class="mono">dddtw2018@gmail.com</a>{' '}
            查詢、更正或請求刪除你的個人資料。
          </>
        )
      }
    </p>

    <h3 id="member-data">{isEn ? 'Member Achievement Records' : '會員成就紀錄（補登／合併／刪除）'}</h3>
    <p class="gov-p">
      {
        isEn
          ? 'The My Journey page matches your email against historical event registration lists. Records may be incomplete: some 2019 events had no digital list, and registrations under a different email are counted separately.'
          : '「我的參與旅程」頁面以 email 比對歷年活動報名名單。紀錄可能不完整：2019 年部分場次沒有電子名單；用不同 email 報名的紀錄會被視為不同人。'
      }
    </p>
    <p class="gov-p">
      {
        isEn ? (
          <>
            To <strong>add a missing record</strong>（with proof of attendance, e.g. a ticket or photo）,{' '}
            <strong>merge records</strong> across multiple emails, or <strong>remove</strong> your
            achievement data entirely, email{' '}
            <a href="mailto:dddtw2018@gmail.com?subject=Member%20data%20request" class="mono">dddtw2018@gmail.com</a>{' '}
            from the address in question. The core team reviews each request; changes take effect at the
            next site build. Removal requests are honored unconditionally.
          </>
        ) : (
          <>
            如需<strong>補登</strong>遺漏的參與紀錄（請附出席佐證，如票券或活動照片）、
            <strong>合併</strong>多個 email 的紀錄，或<strong>完全刪除</strong>你的成就資料，
            請以該 email 來信{' '}
            <a href="mailto:dddtw2018@gmail.com?subject=%E6%9C%83%E5%93%A1%E8%B3%87%E6%96%99%E7%94%B3%E8%AB%8B" class="mono">dddtw2018@gmail.com</a>。
            核心團隊會逐案審核，變更於下次網站建置時生效；刪除請求無條件受理。
          </>
        )
      }
    </p>
  </section>

  <!-- 行為準則 -->
  <section class="container container--narrow section">
    <h2 class="kb-label kb-label--rule gov-h" id="coc">{isEn ? 'Code of Conduct' : '行為準則'}</h2>

    <h3>{isEn ? 'Expected Behavior' : '期望行為'}</h3>
    <p class="gov-p">
      {
        isEn
          ? 'Treat one another with respect, keep discussions friendly, and debate ideas rather than people. Participants of all backgrounds and experience levels are welcome.'
          : '尊重彼此、友善討論、對事不對人；歡迎不同背景與經驗層級的參與者。'
      }
    </p>

    <h3>{isEn ? 'Unacceptable Behavior' : '不容忍行為'}</h3>
    <p class="gov-p">
      {
        isEn
          ? 'Harassment, discrimination, or personal attacks of any kind. This applies to speakers as well — talks must not attack individuals or other communities.'
          : '任何形式的騷擾、歧視與人身攻擊；講者亦同，分享中不得攻擊他人或其他社群。'
      }
    </p>

    <h3>{isEn ? 'Enforcement & Reporting' : '違規處理與申訴'}</h3>
    <p class="gov-p">
      {
        isEn ? (
          <>
            Depending on severity, violations may result in a warning or removal from the event. To
            report an issue, reach out to any volunteer on site or email{' '}
            <a href="mailto:dddtw2018@gmail.com" class="mono">dddtw2018@gmail.com</a> — all reports
            are handled confidentially.
          </>
        ) : (
          <>
            違規將視情節警告或請離；申訴可洽現場志工或來信{' '}
            <a href="mailto:dddtw2018@gmail.com" class="mono">dddtw2018@gmail.com</a>，一律保密處理。
          </>
        )
      }
    </p>
  </section>
</Base>
