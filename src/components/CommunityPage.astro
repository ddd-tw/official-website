---
import Base from '../layouts/Base.astro';
import type { Locale } from '../i18n/ui';

const locale = (Astro.currentLocale ?? 'zh') as Locale;
const isEn = locale === 'en';
const prefix = isEn ? '/en' : '';

const platforms = isEn
  ? [
      {
        title: 'Facebook Group',
        desc: 'The home base for day-to-day discussion and event announcements.',
        url: 'https://www.facebook.com/groups/dddesigntw',
        cta: 'Join the group',
      },
      {
        title: 'Facebook Page',
        desc: 'Official announcements.',
        url: 'https://www.facebook.com/DDDCommunity.tw/',
        cta: 'Follow the page',
      },
      {
        title: 'Line Community',
        desc: 'Real-time chat and Q&A.',
        url: 'https://line.me/ti/g2/aiNGJvViOJIxp7tV-EgNvJ2Id5ae1jBpecKSnA?utm_source=invitation&utm_medium=link_copy&utm_campaign=default',
        cta: 'Join the community',
      },
      {
        title: 'YouTube',
        desc: 'Recordings of meetups and conference talks.',
        url: 'https://www.youtube.com/channel/UCydw7dbEksG3axEMjHy4BxQ',
        cta: 'Subscribe',
      },
      {
        title: 'X (Twitter)',
        desc: 'Short updates and announcements.',
        url: 'https://x.com/DddTaiwan',
        cta: 'Follow @DddTaiwan',
      },
      {
        title: 'Accupass',
        desc: 'Where new events are published and tickets are booked.',
        url: 'https://www.accupass.com/organizer/detail/2204070436062239115110',
        cta: 'See events',
      },
      {
        title: 'KKTIX',
        desc: 'Registration archive for earlier events.',
        url: 'https://dddtaiwan.kktix.cc/',
        cta: 'Past events',
      },
      {
        title: 'Email',
        desc: 'General inquiries: dddtw2018@gmail.com',
        url: 'mailto:dddtw2018@gmail.com',
        cta: 'Email us',
      },
    ]
  : [
      {
        title: 'Facebook 社團',
        desc: '日常討論與活動公告的主要據點。',
        url: 'https://www.facebook.com/groups/dddesigntw',
        cta: '加入社團',
      },
      {
        title: 'Facebook 粉專',
        desc: '官方訊息發布。',
        url: 'https://www.facebook.com/DDDCommunity.tw/',
        cta: '追蹤粉專',
      },
      {
        title: 'Line 社群',
        desc: '即時交流與問答。',
        url: 'https://line.me/ti/g2/aiNGJvViOJIxp7tV-EgNvJ2Id5ae1jBpecKSnA?utm_source=invitation&utm_medium=link_copy&utm_campaign=default',
        cta: '加入 Line 社群',
      },
      {
        title: 'YouTube',
        desc: 'Meetup 與年會錄影回放。',
        url: 'https://www.youtube.com/channel/UCydw7dbEksG3axEMjHy4BxQ',
        cta: '訂閱頻道',
      },
      {
        title: 'X（Twitter）',
        desc: '短訊息與活動快訊。',
        url: 'https://x.com/DddTaiwan',
        cta: '追蹤 @DddTaiwan',
      },
      {
        title: 'Accupass',
        desc: '新活動的發布與報名平台。',
        url: 'https://www.accupass.com/organizer/detail/2204070436062239115110',
        cta: '查看活動',
      },
      {
        title: 'KKTIX',
        desc: '早期活動的報名紀錄。',
        url: 'https://dddtaiwan.kktix.cc/',
        cta: '歷屆活動',
      },
      {
        title: 'Email',
        desc: '一般聯繫：dddtw2018@gmail.com',
        url: 'mailto:dddtw2018@gmail.com',
        cta: '來信聯繫',
      },
    ];

const timeline = isEn
  ? [
      { year: '2018', title: 'The community is founded', desc: 'The first meetups begin spreading Domain-Driven Design in Taiwan.' },
      { year: '2019', title: 'Monthly meetups take shape', desc: 'Seven sessions across the year — from AWS and LinkedIn practice stories to student teams.' },
      { year: '2020', title: 'First annual conference', desc: "Taiwan's first large-scale DDD conference (Nov 27–28), plus the Legacy Code study group." },
      { year: '2021', title: 'Everything moves online', desc: 'Under the pandemic, the "Footprints" conference runs on GatherTown with international speakers.' },
      { year: '2022', title: 'Quiet outside, busy inside', desc: 'The Omicron wave pauses public events — the community spends the year translating the DDD 15th-anniversary anthology into Traditional Chinese.' },
      { year: '2023', title: 'The conference returns', desc: '"Inspiration" (Sep 16–17) brings back talks and hands-on workshops; the book club resumes.' },
      { year: '2024', title: 'Widening the lens', desc: 'The 4th conference goes System Design & Socio-technical; partner sessions with Confluent and more.' },
      { year: '2025', title: 'The most active year yet', desc: 'Nine events including the cross-city DDD Tour (Tainan, Taichung) and the 5th conference on AI-era practices.' },
      { year: '2026', title: 'A new home on the web', desc: 'The new ddd-tw.com launches; monthly meetups are in planning.' },
    ]
  : [
      { year: '2018', title: '社群成立', desc: '從第一場 Meetup 開始，在台灣推廣領域驅動設計。' },
      { year: '2019', title: '每月聚會成形', desc: '全年七場 — 從 AWS、LinkedIn 的實務分享到學生團隊的實踐故事。' },
      { year: '2020', title: '首屆年會', desc: '台灣第一場大型 DDD 年會（11/27–28），同年還有 Legacy Code 讀書會。' },
      { year: '2021', title: '全面轉線上', desc: '疫情之下，年會「足跡」於 GatherTown 舉行，海外講者跨海參與。' },
      { year: '2022', title: '對外蟄伏，對內耕耘', desc: 'Omicron 疫情讓公開活動暫停 — 社群把這一年投入《DDD: The First 15 Years》繁中翻譯。' },
      { year: '2023', title: '年會重啟', desc: '第三屆「啟發」（9/16–17）帶回演講與實作工作坊，讀書會也回歸。' },
      { year: '2024', title: '視野拓寬', desc: '第四屆年會走向 System Design & Socio-technical，並與 Confluent 等夥伴合辦聚會。' },
      { year: '2025', title: '最活躍的一年', desc: '九場活動 — DDD Tour 跨城巡迴（台南、台中）與第五屆年會「AI 時代軟體開發方法」。' },
      { year: '2026', title: '網路上的新家', desc: '新版 ddd-tw.com 上線，每月聚會規劃中。' },
    ];
---

<Base title={isEn ? 'Community — DDD Taiwan' : '社群 — DDD Taiwan'}>
  <div class="container page-head">
    <p class="eyebrow">Community</p>
    <h1>
      {
        isEn ? (
          <>
            Find your <span class="hl">people</span>
          </>
        ) : (
          <>
            社群與<span class="hl">人</span>
          </>
        )
      }
    </h1>
    <p style="max-width: 680px; color: var(--ink-mid);">
      {
        isEn
          ? 'Founded in 2018, DDD Taiwan is a volunteer-run, non-profit community that has co-hosted events with Agile Taipei, Agile Hsinchu, and other communities. Find your channel and join the conversation.'
          : 'DDD Taiwan 成立於 2018 年，是非營利、志工經營的技術社群，曾與 Agile Taipei、Agile Hsinchu 等社群合辦活動。找到你的頻道，加入討論。'
      }
    </p>
  </div>

  <section class="container section">
    <div class="grid-3">
      {
        platforms.map((p) => (
          <a class="card" href={p.url}>
            <h2 style="font-size: 18px; margin: 0 0 8px;">{p.title}</h2>
            <p style="font-size: 14px; color: var(--ink-mid); margin: 0 0 14px;">{p.desc}</p>
            <span style="font-size: 13px; color: var(--brand-strong);">{p.cta} →</span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="container section">
    <p class="eyebrow eyebrow--accent" style="margin: 0 0 6px;">History</p>
    <h2 style="font-size: 26px; margin: 0 0 20px;">{isEn ? 'Our journey' : '社群足跡'}</h2>
    <div class="card">
      <ul class="row-list">
        {
          timeline.map((t) => (
            <li>
              <div class="row" style="align-items: flex-start; padding: 14px 8px;">
                <span class="row__date">{t.year}</span>
                <span>
                  <strong>{t.title}</strong>
                  <br />
                  <span style="font-size: 13.5px; color: var(--ink-mid);">{t.desc}</span>
                </span>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Base>
