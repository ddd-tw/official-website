---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import type { Locale } from '../i18n/ui';

const locale = (Astro.currentLocale ?? 'zh') as Locale;
const isEn = locale === 'en';

const books = await getCollection('books');
// 四組主題分類，順序即「先懂問題 → 一起探索 → 建模落地 → 讓系統長青」的閱讀旅程；
// 組內順序沿用 books.json 的陣列順序（入門 → 深入）。
const bookCategories = [
  {
    key: 'strategy',
    title: isEn ? 'Understand the Problem — Strategy & Sense-Making' : '先懂問題 — 策略與情境',
    desc: isEn
      ? 'Before any solution: why are we doing this, where are we, and what kind of situation is it?'
      : '在談任何解法之前：為什麼做、身在何處、這是什麼樣的情境？',
  },
  {
    key: 'collaboration',
    title: isEn ? 'Explore Together — Collaborative Modelling' : '一起探索 — 協作建模與需求',
    desc: isEn
      ? 'Put everyone in one room and turn scattered knowledge into shared language.'
      : '把所有人放進同一個房間，讓分散的知識變成共同語言。',
  },
  {
    key: 'ddd-core',
    title: isEn ? 'Model the Domain — DDD Core' : '建模落地 — DDD 核心',
    desc: isEn
      ? 'From your first read to the source texts — strategic and tactical Domain-Driven Design.'
      : '從第一本入門到原典 — 領域驅動設計的戰略與戰術。',
  },
  {
    key: 'architecture',
    title: isEn ? 'Evolve the System — Architecture & Resilience' : '讓系統長青 — 架構與韌性',
    desc: isEn
      ? 'Turn understanding into systems that keep evolving: viewpoints, SaaS architecture, SRE.'
      : '把理解變成能持續演進的系統：多元視角、SaaS 架構與 SRE。',
  },
] as const;
const booksByCategory = bookCategories.map((c) => ({
  ...c,
  items: books.filter((b) => b.data.category === c.key),
}));
const videos = await getCollection('videos');
// 五種內容類型，依「案例 → 演講 → 訪談 → 座談 → 技法」排序；分類依內容本質而非活動場次，
// 讓「為什麼推薦這支」一眼可見，而不是只有一個模糊的「推薦」標籤。
const videoCategories = [
  {
    key: 'case-study',
    title: isEn ? 'Case Studies — DDD in Real Systems' : '實戰案例 — 真實系統裡的 DDD',
    desc: isEn
      ? 'Not theory — each talk names the actual system and constraints the speaker worked within.'
      : '不是紙上談兵，這些分享都指名了實際交手的系統與限制條件。',
  },
  {
    key: 'keynote',
    title: isEn ? 'Keynotes — Deep Technical Perspectives' : '主題演講 — 深度技術視角',
    desc: isEn
      ? 'Full conference talks — deep technical sessions from international, overseas, and local speakers.'
      : '大型技術會議的完整演講，匯集國際、海外與在地講者的深度技術分享。',
  },
  {
    key: 'interview',
    title: isEn ? 'Interviews' : '人物專訪',
    desc: isEn
      ? 'Conversations with practitioners inside and outside the community.'
      : '與社群內外的實踐者對話，聊他們怎麼想、怎麼做。',
  },
  {
    key: 'panel',
    title: isEn ? 'Panel Discussions' : '座談討論',
    desc: isEn
      ? "Multiple speakers in dialogue — including DDD's limitations, not just its strengths."
      : '多位講者交叉對話，不只講優點，也談 DDD 的侷限。',
  },
  {
    key: 'technique',
    title: isEn ? 'Techniques — Concrete Methods' : '技術方法 — 拆解具體技法',
    desc: isEn
      ? 'Focused on a single technique or principle, from SOLID to microservice decomposition strategies.'
      : '聚焦單一技法或原則，從 SOLID 到微服務拆分策略。',
  },
] as const;
const featuredVideos = videos.filter((v) => v.data.featured);
// 精選已置頂為大縮圖卡，分類清單裡就不重複列出。
const videosByCategory = videoCategories.map((c) => ({
  ...c,
  items: videos.filter((v) => v.data.category === c.key && !v.data.featured),
}));
// 頻道縮寫，作為每列右側的來源標籤（呼應參考頁的 kind tag）。
const channelTag = (channel?: string) => {
  switch (channel) {
    case 'AWS Events':
      return 'AWS';
    case 'Virtual Domain-Driven Design':
      return 'Virtual DDD';
    case 'Domain-Driven Design Taiwan':
      return 'DDD TW';
    default:
      return channel;
  }
};
const youtubeThumb = (url: string) => {
  const m = url.match(/(?:v=|youtu\.be\/)([\w-]{11})/);
  return m ? `https://i.ytimg.com/vi/${m[1]}/hqdefault.jpg` : undefined;
};
const allPosts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
// 依當前語言過濾文章；該語言沒有文章時退回顯示全部。
const localizedPosts = allPosts.filter((p) => p.data.lang === locale);
const posts = localizedPosts.length > 0 ? localizedPosts : allPosts;

const repos = [
  {
    name: 'ddd-tw/ddd-tutorial',
    group: 'projects',
    tag: isEn ? 'Project' : '社群專案',
    desc: isEn ? 'A hands-on DDD tutorial' : 'DDD 實作教學範例',
    url: 'https://github.com/ddd-tw/ddd-tutorial',
  },
  {
    name: 'ddd-tw/ddd-events',
    group: 'projects',
    tag: isEn ? 'Project' : '社群專案',
    desc: isEn ? 'Meetup & study-group archive' : '歷屆活動資源紀錄',
    url: 'https://github.com/ddd-tw/ddd-events',
  },
  {
    name: 'ddd-tw/2025Summit',
    group: 'projects',
    tag: isEn ? 'Project' : '社群專案',
    desc: isEn ? '2025 Summit project' : '2025 Summit 專案',
    url: 'https://github.com/ddd-tw/2025Summit',
  },
  {
    name: 'aws-samples/designing-cloud-native-microservices-on-aws',
    group: 'members',
    tag: '⭐ 320+',
    desc: isEn ? 'Cloud-native microservices design' : 'Cloud-native 微服務設計範例',
    url: 'https://github.com/aws-samples/designing-cloud-native-microservices-on-aws',
  },
  {
    name: 'humank/ddd-practitioners-ref',
    group: 'members',
    tag: '⭐ 320+',
    desc: isEn ? "A DDD practitioner's reference" : 'DDD 實踐者參考',
    url: 'https://github.com/humank/ddd-practitioners-ref',
  },
  {
    name: 'ddd-crew/ddd-starter-modelling-process',
    group: 'external',
    tag: isEn ? 'External' : '外部推薦',
    desc: isEn ? 'DDD starter modelling process' : 'DDD 建模起手流程',
    url: 'https://github.com/ddd-crew/ddd-starter-modelling-process',
  },
  {
    name: 'ddd-crew/context-mapping',
    group: 'external',
    tag: isEn ? 'External' : '外部推薦',
    desc: isEn ? 'Context-mapping patterns' : 'Context Mapping 模式',
    url: 'https://github.com/ddd-crew/context-mapping',
  },
];
const repoGroups = [
  { key: 'projects', title: isEn ? 'DDD Taiwan projects' : 'DDD Taiwan 專案' },
  { key: 'members', title: isEn ? 'By community members' : '社群成員作品' },
  { key: 'external', title: isEn ? 'Recommended' : '外部推薦' },
].map((g) => ({ ...g, items: repos.filter((r) => r.group === g.key) }));

const fmtDate = (d: Date) => d.toISOString().slice(0, 10);

const site = Astro.site?.toString() ?? 'https://ddd-tw.com/';
const videoId = (url: string) => url.match(/(?:v=|youtu\.be\/)([\w-]{11})/)?.[1];
// 精選影片輸出 VideoObject 清單，讓搜尋引擎與 AI 認得這些是可觀看的演講內容。
const videoLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: isEn ? 'DDD Taiwan — recommended talks & interviews' : 'DDD Taiwan 精選演講與訪談',
  itemListElement: videos.map((v, i) => {
    const id = videoId(v.data.url);
    return {
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'VideoObject',
        name: isEn ? (v.data.titleEn ?? v.data.title) : v.data.title,
        description: (isEn ? v.data.highlightEn : v.data.highlight) ?? v.data.title,
        ...(id ? { thumbnailUrl: `https://i.ytimg.com/vi/${id}/hqdefault.jpg` } : {}),
        ...(id ? { embedUrl: `https://www.youtube.com/embed/${id}` } : {}),
        url: v.data.url,
        ...(v.data.year ? { uploadDate: `${v.data.year}-01-01` } : {}),
        ...(v.data.channel ? { publisher: v.data.channel } : {}),
        inLanguage: isEn ? 'en' : 'zh-TW',
      },
    };
  }),
};
// 書單輸出 schema.org/Book。
const bookLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: isEn ? 'DDD Taiwan — recommended reading' : 'DDD Taiwan 推薦書單',
  itemListElement: books.map((b, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Book',
      name: b.data.title,
      author: { '@type': 'Person', name: b.data.author },
      datePublished: String(b.data.year),
      ...(b.data.url ? { url: b.data.url } : {}),
    },
  })),
};
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'DDD Taiwan', item: site },
    {
      '@type': 'ListItem',
      position: 2,
      name: isEn ? 'Knowledge' : '知識庫',
      item: new URL(`${isEn ? '/en' : ''}/knowledge/`, site).toString(),
    },
  ],
};
---

<Base
  title={isEn ? 'Knowledge Base — DDD Taiwan' : '知識庫 — DDD Taiwan'}
  jsonLd={[videoLd, bookLd, breadcrumb]}
>
  <div class="container page-head">
    <p class="eyebrow">Knowledge</p>
    <h1>
      {
        isEn ? (
          <>
            The community's <span class="hl">library</span>
          </>
        ) : (
          <>
            知識<span class="hl">庫</span>
          </>
        )
      }
    </h1>
  </div>

  <div class="container" style="margin-top: 36px;">
    <div class="kb-tabs" role="tablist" aria-label={isEn ? 'Knowledge base sections' : '知識庫分區'}>
      <button role="tab" data-tab="books" aria-selected="true">Books</button>
      <button role="tab" data-tab="papers" aria-selected="false">Papers</button>
      <button role="tab" data-tab="video" aria-selected="false">Video</button>
      <button role="tab" data-tab="github" aria-selected="false">GitHub</button>
    </div>
  </div>

  <section class="container section" id="panel-books" data-kb-panel>
    <h2 style="position: absolute; left: -9999px;">Books</h2>
    <p class="kb-intro">
      {
        isEn
          ? 'Four themed shelves, ordered as a journey: understand the problem, explore together, model the domain, then evolve the system. Within each shelf, books run from approachable to deep.'
          : '四個主題書架，依「先懂問題 → 一起探索 → 建模落地 → 讓系統長青」的旅程排列；每個書架內由入門到深入。'
      }
    </p>
    {
      booksByCategory.map((cat) => (
        <div class="kb-section">
          <p class="kb-label kb-label--rule">{cat.title}</p>
          <p class="kb-desc">{cat.desc}</p>
          <div class="kb-grid">
            {cat.items.map((b) =>
              b.data.url ? (
                <a class="kb-tile kb-tile--cover" href={b.data.url}>
                  <span class="kb-tile__cover">
                    {b.data.cover ? (
                      <img src={b.data.cover} alt={`《${b.data.title}》`} width="52" height="74" loading="lazy" />
                    ) : (
                      <span style={`background: ${b.data.coverColor};`} />
                    )}
                  </span>
                  <span class="kb-tile__body">
                    <span class="kb-tile__title">
                      {b.data.title}
                      <span class="kb-tile__arrow" aria-hidden="true">↗</span>
                    </span>
                    <span class="kb-tile__sub">{b.data.author} · {b.data.year}</span>
                    <span class="kb-tile__desc">{b.data.summary}</span>
                  </span>
                </a>
              ) : (
                <div class="kb-tile kb-tile--cover">
                  <span class="kb-tile__cover">
                    {b.data.cover ? (
                      <img src={b.data.cover} alt={`《${b.data.title}》`} width="52" height="74" loading="lazy" />
                    ) : (
                      <span style={`background: ${b.data.coverColor};`} />
                    )}
                  </span>
                  <span class="kb-tile__body">
                    <span class="kb-tile__title">{b.data.title}</span>
                    <span class="kb-tile__sub">{b.data.author} · {b.data.year}</span>
                    <span class="kb-tile__desc">{b.data.summary}</span>
                  </span>
                </div>
              )
            )}
          </div>
        </div>
      ))
    }
    <p class="kb-note">
      {
        isEn
          ? "Read any of these? We'd love to feature your book review."
          : '讀過這些書嗎？歡迎投稿你的閱讀心得。'
      }
    </p>
  </section>

  <section class="container section" id="panel-papers" data-kb-panel>
    <h2 style="position: absolute; left: -9999px;">Papers</h2>
    <p class="kb-intro">
      {
        isEn
          ? 'Practical writing from community members, plus articles republished with the original authors’ permission.'
          : '社群成員的實務文章，以及取得原作者授權轉載的好文。'
      }
    </p>
    <div class="kb-section">
      <p class="kb-label kb-label--rule">{isEn ? 'Articles' : '文章'}</p>
      <div class="kb-grid">
        {
          posts.map((p) => (
            <a class="kb-tile" href={`${p.data.lang === 'en' ? '/en' : ''}/posts/${p.id}/`}>
              <span class="kb-tile__top">
                <span class="kb-tile__meta mono">{fmtDate(p.data.pubDate)}</span>
                {p.data.tags?.[0] && <span class="kb-tile__tag">{p.data.tags[0]}</span>}
              </span>
              <span class="kb-tile__title">
                {p.data.title}
                <span class="kb-tile__arrow" aria-hidden="true">↗</span>
              </span>
              <span class="kb-tile__desc">{p.data.description}</span>
            </a>
          ))
        }
      </div>
    </div>
    <p class="kb-note">
      {
        isEn ? (
          <>
            Want to contribute or recommend an article? Submissions go through community review
            before publishing; republished pieces must include the original author's permission —
            open a pull request on <a href="https://github.com/ddd-tw/official-website">GitHub</a>
            or <a href="mailto:dddtw2018@gmail.com">email us</a>.
          </>
        ) : (
          <>
            想投稿或推薦好文？文章經社群 Review 後發布；轉載需附原作者授權紀錄 — 歡迎到
            <a href="https://github.com/ddd-tw/official-website">GitHub</a> 開 Pull Request，或
            <a href="mailto:dddtw2018@gmail.com">來信給我們</a>。
          </>
        )
      }
    </p>
  </section>

  <section class="container section" id="panel-video" data-kb-panel>
    <h2 style="position: absolute; left: -9999px;">Video</h2>
    {
      featuredVideos.length > 0 && (
        <>
          <p class="kb-label">{isEn ? 'Featured' : '精選'}</p>
          <div class="feat-grid">
            {featuredVideos.map((v) => (
              <a class="feat-card" href={v.data.url} target="_blank" rel="noopener noreferrer">
                <span class="feat-card__thumb">
                  <img
                    src={youtubeThumb(v.data.url)}
                    alt={isEn ? (v.data.titleEn ?? v.data.title) : v.data.title}
                    width="480"
                    height="270"
                    loading="lazy"
                  />
                  <span class="feat-card__play" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z" /></svg>
                  </span>
                </span>
                <span class="feat-card__title">{isEn ? (v.data.titleEn ?? v.data.title) : v.data.title}</span>
                {(isEn ? v.data.highlightEn : v.data.highlight) && (
                  <span class="feat-card__event">{isEn ? v.data.highlightEn : v.data.highlight}</span>
                )}
              </a>
            ))}
          </div>
        </>
      )
    }
    {
      videosByCategory
        .filter((cat) => cat.items.length > 0)
        .map((cat) => (
          <div class="kb-section">
            <p class="kb-label kb-label--rule">{cat.title}</p>
            <p class="kb-desc">{cat.desc}</p>
            <div class="kb-grid">
              {cat.items.map((v) => (
                <a class="kb-tile" href={v.data.url} target="_blank" rel="noopener noreferrer">
                  <span class="kb-tile__top">
                    <span class="kb-tile__meta mono">{v.data.year ?? ''}</span>
                    <span class="kb-tile__tag">{channelTag(v.data.channel)}</span>
                  </span>
                  <span class="kb-tile__title">
                    {isEn ? (v.data.titleEn ?? v.data.title) : v.data.title}
                    <span class="kb-tile__arrow" aria-hidden="true">↗</span>
                  </span>
                  {(isEn ? v.data.highlightEn : v.data.highlight) && (
                    <span class="kb-tile__desc">{isEn ? v.data.highlightEn : v.data.highlight}</span>
                  )}
                </a>
              ))}
            </div>
          </div>
        ))
    }
    <a class="btn btn--ghost" style="margin-top: 28px;" href="https://www.youtube.com/channel/UCydw7dbEksG3axEMjHy4BxQ">
      {isEn ? 'Visit our YouTube channel' : '前往 YouTube 頻道'}
    </a>
  </section>

  <section class="container section" id="panel-github" data-kb-panel>
    <h2 style="position: absolute; left: -9999px;">GitHub</h2>
    <p class="kb-intro">
      {
        isEn
          ? 'Open-source projects from the community, plus reference repositories worth bookmarking.'
          : '社群的開源專案，以及值得收藏的參考程式庫。'
      }
    </p>
    {
      repoGroups.map((g) => (
        <div class="kb-section">
          <p class="kb-label kb-label--rule">{g.title}</p>
          <div class="kb-grid">
            {g.items.map((r) => (
              <a class="kb-tile" href={r.url} target="_blank" rel="noopener noreferrer">
                <span class="kb-tile__top">
                  <span class="kb-tile__meta">GitHub</span>
                  <span class="kb-tile__tag">{r.tag}</span>
                </span>
                <span class="kb-tile__title kb-tile__title--mono">
                  {r.name}
                  <span class="kb-tile__arrow" aria-hidden="true">↗</span>
                </span>
                <span class="kb-tile__desc">{r.desc}</span>
              </a>
            ))}
          </div>
        </div>
      ))
    }
    <p class="kb-note">
      {
        isEn
          ? 'Built your own DDD sample code? Contributions are welcome.'
          : '歡迎貢獻你的 DDD 範例程式碼。'
      }
    </p>
    <a class="btn btn--ghost" style="margin-top: 14px;" href="https://github.com/ddd-tw">github.com/ddd-tw</a>
  </section>

  <script>
    const PANELS = ['books', 'papers', 'video', 'github'];

    const show = (key: string) => {
      PANELS.forEach((k) => {
        const panel = document.getElementById(`panel-${k}`);
        if (panel) panel.style.display = k === key ? '' : 'none';
        document
          .querySelector(`[data-tab="${k}"]`)
          ?.setAttribute('aria-selected', String(k === key));
      });
    };

    const fromHash = location.hash.slice(1);
    show(PANELS.includes(fromHash) ? fromHash : 'books');

    document.querySelectorAll<HTMLButtonElement>('[data-tab]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const key = btn.dataset.tab!;
        history.replaceState(null, '', `#${key}`);
        show(key);
      });
    });
  </script>
</Base>
