---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import type { Locale } from '../i18n/ui';

const locale = (Astro.currentLocale ?? 'zh') as Locale;
const isEn = locale === 'en';

const books = await getCollection('books');
const allPosts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
// 依當前語言過濾文章；該語言沒有文章時退回顯示全部。
const localizedPosts = allPosts.filter((p) => p.data.lang === locale);
const posts = localizedPosts.length > 0 ? localizedPosts : allPosts;

const paperSteps = isEn
  ? [
      { n: '01', title: 'Agent gathers', desc: 'Relevant articles are collected automatically' },
      { n: '02', title: 'Author consent', desc: 'Original authors are contacted for permission' },
      { n: '03', title: 'Community review', desc: 'Community members review the content' },
      { n: '04', title: 'Published', desc: 'Approved pieces go live on the site' },
    ]
  : [
      { n: '01', title: 'Agent 蒐集', desc: '自動從網路抓取相關文章' },
      { n: '02', title: '作者授權', desc: '聯繫原作者取得授權同意' },
      { n: '03', title: '社群 Review', desc: '由社群成員審核內容' },
      { n: '04', title: '正式發布', desc: '通過後發布至網站' },
    ];

const repos = [
  {
    name: 'ddd-tw/2025Summit',
    note: isEn ? 'Community project' : '社群專案',
    url: 'https://github.com/ddd-tw/2025Summit',
  },
  {
    name: 'ddd-crew/ddd-starter-modelling-process',
    note: isEn ? 'Recommended' : '外部推薦',
    url: 'https://github.com/ddd-crew/ddd-starter-modelling-process',
  },
  {
    name: 'ddd-crew/context-mapping',
    note: isEn ? 'Recommended' : '外部推薦',
    url: 'https://github.com/ddd-crew/context-mapping',
  },
];

const fmtDate = (d: Date) => d.toISOString().slice(0, 10);
---

<Base title={isEn ? 'Knowledge Base — DDD Taiwan' : '知識庫 — DDD Taiwan'}>
  <div class="container page-head">
    <p class="eyebrow">Knowledge</p>
    <h1>
      {
        isEn ? (
          <>
            The community's <span class="hl">library</span>
          </>
        ) : (
          <>
            知識<span class="hl">庫</span>
          </>
        )
      }
    </h1>
  </div>

  <section class="container section">
    <h2>Books</h2>
    <div class="grid-2">
      {
        books.map((b) => (
          <div class="card card--hover" style="display: flex; gap: 18px;">
            <div
              style={`flex: 0 0 44px; height: 62px; border-radius: 4px; background: ${b.data.coverColor};`}
            />
            <div>
              <h3 style="font-size: 16px; margin: 0;">{b.data.title}</h3>
              <p style="font-size: 13px; color: var(--ink-faint); margin: 4px 0;">
                {b.data.author} · {b.data.year}
              </p>
              <p style="font-size: 14px; color: var(--ink-mid); margin: 0;">{b.data.summary}</p>
            </div>
          </div>
        ))
      }
    </div>
    <p style="color: var(--ink-faint); font-size: 14px;">
      {
        isEn
          ? "Read any of these? We'd love to feature your book review."
          : '讀過這些書嗎？歡迎投稿你的閱讀心得。'
      }
    </p>
  </section>

  <section class="container section">
    <h2>Papers</h2>
    <div class="grid-2" style="grid-template-columns: repeat(4, 1fr);">
      {
        paperSteps.map((s) => (
          <div class="card" style="padding: 20px;">
            <span class="mono" style="color: var(--accent); font-size: 13px;">
              {s.n}
            </span>
            <h3 style="font-size: 15px; margin: 8px 0 4px;">{s.title}</h3>
            <p style="font-size: 13px; color: var(--ink-mid); margin: 0;">{s.desc}</p>
          </div>
        ))
      }
    </div>

    <h3 style="margin-top: 28px;">{isEn ? 'Latest articles' : '最新文章'}</h3>
    <ul class="row-list">
      {
        posts.map((p) => (
          <li>
            <a href={`/posts/${p.id}/`}>
              <span class="row__date">{fmtDate(p.data.pubDate)}</span>
              <span>{p.data.title}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="container section">
    <h2>Video</h2>
    <div style="display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 16px;">
      <span class="chip">{isEn ? 'Meetup replays' : 'Meetup 回放'}</span>
      <span class="chip">{isEn ? 'Conference talks' : '年會演講'}</span>
      <span class="chip">{isEn ? 'Recommended videos' : '推薦影片'}</span>
    </div>
    <a class="btn btn--ghost" href="https://www.youtube.com/@dddtaiwan">
      {isEn ? 'Visit our YouTube channel' : '前往 YouTube 頻道'}
    </a>
  </section>

  <section class="container section">
    <h2>GitHub</h2>
    <ul class="row-list">
      {
        repos.map((r) => (
          <li>
            <a href={r.url}>
              <span class="mono" style="font-size: 13px;">
                {r.name}
              </span>
              <span style="font-size: 13px; color: var(--ink-faint);">{r.note}</span>
            </a>
          </li>
        ))
      }
    </ul>
    <p style="color: var(--ink-faint); font-size: 14px;">
      {
        isEn
          ? 'Built your own DDD sample code? Contributions are welcome.'
          : '歡迎貢獻你的 DDD 範例程式碼。'
      }
    </p>
    <a class="btn btn--ghost" href="https://github.com/ddd-tw">github.com/ddd-tw</a>
  </section>
</Base>
