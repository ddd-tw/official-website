---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft && data.lang === 'zh');
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmtDate = (d: Date) => d.toISOString().slice(0, 10);

const site = Astro.site?.toString() ?? 'https://ddd-tw.com/';
const postUrl = new URL(`/posts/${post.id}/`, site).toString();
const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  inLanguage: post.data.lang === 'en' ? 'en' : 'zh-TW',
  datePublished: post.data.pubDate.toISOString().slice(0, 10),
  author: { '@type': 'Person', name: post.data.author },
  publisher: { '@id': `${site}#organization` },
  image: new URL('/og-image.png', site).toString(),
  mainEntityOfPage: postUrl,
  url: postUrl,
  keywords: post.data.tags,
  ...(post.data.source ? { isBasedOn: post.data.source } : {}),
};
const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'DDD Taiwan', item: site },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Knowledge',
      item: new URL('/knowledge/', site).toString(),
    },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: postUrl },
  ],
};
---

<Base
  title={`${post.data.title} — DDD Taiwan`}
  description={post.data.description}
  jsonLd={[articleLd, breadcrumb]}
>
  <article class="container container--narrow page-head">
    <p class="eyebrow">
      <span class="mono">{fmtDate(post.data.pubDate)}</span> · {post.data.author}
    </p>
    <h1>{post.data.title}</h1>
    {
      post.data.source && (
        <p style="font-size: 14px; color: var(--ink-faint);">
          原文出處：<a href={post.data.source}>{post.data.source}</a>（已取得作者授權轉載）
        </p>
      )
    }
    <div class="section" style="font-size: 16px;">
      <Content />
    </div>
  </article>
</Base>
