---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const events = (await getCollection('events')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const meetups = events.filter((e) => e.data.type !== 'conference');
const conferences = events.filter((e) => e.data.type === 'conference');

const fmt = (d: Date) =>
  `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}`;
---

<Base title="參與活動 — DDD Taiwan">
  <div class="container page-head">
    <p class="eyebrow">Events</p>
    <h1>參與<span class="hl">活動</span></h1>
  </div>

  <section class="container section">
    <div class="card">
      <div style="display: flex; align-items: center; gap: 14px; flex-wrap: wrap;">
        <h2 style="margin: 0;">Meetup</h2>
        <span class="chip">下一場籌備中</span>
      </div>
      <p style="color: var(--ink-mid);">
        定期舉辦的技術聚會，提供報名資訊、場地與議程預告；活動結束後補充錄影回放連結。
      </p>
      <div class="grid-3" style="margin: 20px 0;">
        <div class="tile"><strong>日期</strong><br />待公告</div>
        <div class="tile"><strong>場地</strong><br />待公告</div>
        <div class="tile"><strong>議程預告</strong><br />待公告</div>
      </div>
      <div style="display: flex; gap: 12px; flex-wrap: wrap;">
        <a class="btn btn--ghost" href="https://dddtaiwan.kktix.cc/">KKTIX</a>
        <a class="btn btn--ghost" href="https://www.meetup.com/domain-driven-design-taiwan-meetup-group/">Meetup.com</a>
      </div>

      <h3 style="margin-top: 36px;">歷屆場次</h3>
      <ul class="row-list">
        {
          meetups.map((e) => (
            <li>
              <a href={e.data.link ?? 'https://dddtaiwan.kktix.cc/'}>
                <span class="row__date">{fmt(e.data.date)}</span>
                <span>{e.data.title}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="container section">
    <div class="card">
      <h2 style="margin-top: 0;">Conference</h2>
      <p style="color: var(--ink-mid);">
        年度大會，含主題演講與 Event Storming、Domain Storytelling 等工作坊。贊助洽詢：
        <a href="mailto:conference@ddd-tw.com" class="mono">conference@ddd-tw.com</a>
      </p>
      <ul class="row-list">
        {
          conferences.map((e) => (
            <li>
              <a href={e.data.link}>
                <span class="row__date">{fmt(e.data.date)}</span>
                <span>{e.data.title}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="container section">
    <div class="card">
      <h2 style="margin-top: 0;">Book Club</h2>
      <p style="color: var(--ink-mid);">定期讀書會 — 一起精讀、討論與實作。</p>
      <div class="grid-3" style="margin: 20px 0;">
        <div class="tile"><strong>目前書目</strong><br />待公告</div>
        <div class="tile"><strong>進度</strong><br />—</div>
        <div class="tile"><strong>上一本</strong><br />Pragmatic TDD</div>
      </div>
      <a class="btn btn--ghost" href="/community/">加入方式</a>
    </div>
  </section>
</Base>
