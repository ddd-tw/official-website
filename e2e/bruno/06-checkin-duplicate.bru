meta {
  name: 重複入場攔截
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/checkin/scan
  body: json
  auth: none
}

headers {
  x-admin-token: {{adminToken}}
}

body:json {
  {
    "qrToken": "{{qrToken}}",
    "gate": "e2e-gate"
  }
}

assert {
  res.status: eq 200
}

tests {
  test("同一張票第二次掃描回報 duplicate 與首次入場時間", function () {
    const scan = res.getBody();
    expect(scan.result).to.equal("duplicate");
    expect(scan.firstScannedAt).to.be.a("string");
  });
}
