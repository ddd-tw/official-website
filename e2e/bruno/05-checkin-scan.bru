meta {
  name: 05 驗票入場(成功)
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/checkin/scan
  body: json
  auth: none
}

headers {
  x-admin-token: {{adminToken}}
}

body:json {
  {
    "qrToken": "{{qrToken}}",
    "gate": "e2e-gate"
  }
}

assert {
  res.status: eq 200
}

tests {
  test("首次掃描成功並回報名人資訊", function () {
    const body = res.getBody();
    expect(body.result).to.equal("success");
    expect(body.attendeeName).to.equal("Bruno 志工");
  });
}
